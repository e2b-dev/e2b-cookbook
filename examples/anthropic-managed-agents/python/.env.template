# E2B credentials. E2B_API_KEY runs sandboxes.
# E2B_ACCESS_TOKEN builds templates.
E2B_API_KEY=e2b_...
E2B_ACCESS_TOKEN=sk_e2b_...

# Anthropic application key for creating environments, agents, and sessions.
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic self-hosted environment.
ANTHROPIC_ENVIRONMENT_ID=env_...
ANTHROPIC_ENVIRONMENT_KEY=sk-ant-env-...

# Anthropic webhook endpoint signing key. Required only for the webhook server example.
ANTHROPIC_WEBHOOK_SIGNING_KEY=whsec_...

# Bearer token for app-owned debug endpoints such as GET /sandboxes.
APP_WEBHOOK_ADMIN_TOKEN=replace-with-random-token

# Agent used by send_message.py.
ANTHROPIC_AGENT_ID=agent_...
