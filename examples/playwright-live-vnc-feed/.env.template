# E2B sandbox API key — get one at https://e2b.dev
E2B_API_KEY=

# How long to keep the sandbox alive after the test finishes, in seconds.
# A short hold lets you re-load the noVNC tab and inspect the final page
# state (or DevTools, if you opened them) before the sandbox is killed.
# Default: 60. Set to 0 to kill immediately.
POST_RUN_HOLD_SECONDS=60
